FROM python:3.10-slim

WORKDIR /app

# Install dependencies first — cached layer, only rebuilds when requirements.txt changes
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy entire project so src/ and logs/ are available
COPY . .

# HF Spaces only exposes port 7860
EXPOSE 7860

CMD ["python", "-m", "uvicorn", "src.api.main:app", "--host", "0.0.0.0", "--port", "7860"]
